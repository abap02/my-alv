*&---------------------------------------------------------------------*
*&      Module  GET_CURSOR  INPUT
*&---------------------------------------------------------------------*
*       text
*----------------------------------------------------------------------*
module get_cursor input.

  if gv_cursor is initial.
    get cursor field gv_cursor.
    if gv_cursor is not initial.
      gv_cursor_dynnr = sy-dynnr.
    else.
      clear: gv_cursor_dynnr.
    endif.
  endif.

endmodule.
