*&---------------------------------------------------------------------*
*& Include          ZZ0433_SALV_001_PBO
*&---------------------------------------------------------------------*
*&---------------------------------------------------------------------*
*& Module STATUS_9000 OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
module status_9000 output.
  set pf-status 'S9000'.
  set titlebar 'T9000' with gv_title.
endmodule.
*&---------------------------------------------------------------------*
*& Module SET_SALV_DISPLAY OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
module set_salv_display output.
  perform set_salv_display.
endmodule.
*&---------------------------------------------------------------------*
*& Module SET_CURSOR OUTPUT
*&---------------------------------------------------------------------*
*&
*&---------------------------------------------------------------------*
module set_cursor output.
  check gv_cursor_dynnr eq sy-dynnr.
  if gv_cursor is not initial.
    set cursor field gv_cursor.
    clear: gv_cursor, gv_cursor_dynnr.
  endif.
endmodule.
